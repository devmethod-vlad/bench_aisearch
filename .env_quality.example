# === API aisearch ===
API_BASE_URL=http://localhost:5155
API_SEARCH_PATH=/hybrid-search/search
API_STATUS_PATH=/hybrid-search/info/{task_id}

# === Request body / SearchRequest ===
API_TOP_K=10
TOP_K=10
RESULTS_LIMIT=10

# Для честной оценки качества cache лучше выключать.
API_SEARCH_USE_CACHE=false

# Метрики полезно включать, чтобы видеть настройки прогона и timings.
API_METRICS_ENABLE=true

# Quality benchmark должен уметь анализировать intermediate_results.
API_SHOW_INTERMEDIATE_RESULTS=true

# === Optional presearch ===
API_PRESEARCH_ENABLED=false
API_PRESEARCH_FIELD=
API_PRESEARCH_JSON=

# === Optional array filters ===
# Значения через запятую или точку с запятой.
API_FILTER_ARRAY_ROLE=
API_FILTER_ARRAY_PRODUCT=
API_FILTER_ARRAY_COMPONENT=

# === Optional exact filters ===
API_FILTER_EXACT_SOURCE=
API_FILTER_EXACT_ACTUAL=
API_FILTER_EXACT_SECOND_LINE=

# Полный JSON override для filters. Если задан, имеет приоритет над API_FILTER_ARRAY_* и API_FILTER_EXACT_*.
API_FILTERS_JSON=

# === HTTP timeouts / retry / polling ===
API_SEARCH_TIMEOUT=60
API_SEARCH_RETRY_COUNT=5
API_SEARCH_OVERFLOW_QUERY_TIMEOUT=5
API_SEARCH_QUERY_LIMIT_TIMEOUT=5
API_INFO_INTERVAL=0.5
API_INFO_MAX_TIME=120

API_STATUS_INWORK_STATUS_VALUE=queued,running
API_STATUS_FAIL_STATUS_VALUE=failed,not_found
API_STATUS_STATUS_OK_VALUE=done

# === Response paths ===
RESULTS_PATH=info.results
METRICS_PATH=info.metrics
INTERMEDIATE_RESULTS_PATH=info.intermediate_results

# === Result fields ===
RESULT_ID_FIELD=ext_id
RESULT_QUESTION_FIELD=question
RESULT_ANSWER_FIELD=answer

# Можно оставить пустым: код сам попробует final_score, score_final, score_ce, score_fusion, score_dense, score_lex.
MARGIN_SCORE_FIELD=

# === Quality input data ===
TEST_DATA_PATH=test_data.xlsx
COL_QUERY=test_query
COL_TARGET_ID=target_id
COL_SOURCE=source
COL_QUERY_SOURCE=test_query_source
COL_ANSWER=test_answer

# === Quality metrics ===
METRICS_KS=1,3,5,10

# === Output ===
OUTPUT_BASENAME=bench_results
