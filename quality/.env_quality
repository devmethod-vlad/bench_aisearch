# Путь к XLSX-файлу с тестовыми запросами и целевыми идентификаторами
TEST_DATA_PATH=test_data.xlsx

# Название колонки с текстом тестового запроса в файле TEST_DATA_PATH
COL_QUERY=test_query

# Название колонки с источником запроса (используется для разбивки статистики)
COL_SOURCE=source

# Название колонки с ID целевого вопроса
COL_TARGET_ID=target_id

# название колонки с источником тестового запроса
COL_QUERY_SOURCE=test_query_source

# название колонки с эталонным ответом
COL_ANSWER=test_answer

# Точечный путь к массиву результатов в JSON-ответе API
RESULTS_PATH=info.results

# Точечный путь к словарю с метриками в JSON-ответе API
METRICS_PATH=info.metrics

# Точечный путь к блоку промежуточных результатов (dense/lex/ce) в JSON-ответе API
INTERMEDIATE_RESULTS_PATH=info.intermediate_results

# Имя поля с идентификатором результата в элементах выдачи
RESULT_ID_FIELD=ext_id

# Имя поля с вопросом в элементах выдачи
RESULT_QUESTION_FIELD=question

# Имя поля с ответом документа в элементах выдачи
RESULT_ANSWER_FIELD=answer

# Дополнительные поля результата, которые нужно сохранить в лог (через запятую)
ADDITIONAL_RESULT_FIELDS=answer,analysis,sources,score_final,score_ce,score_lex,score_dense

# Название поля с общим временем поиска по запросу (секунды)
DURATION_FIELD=total_time

# Название поля с временем вычисления эмбеддинга (секунды)
EMBEDDING_TIME_FIELD=embedding_time

# Название поля с временем плотного поиска по векторам (секунды)
VECTOR_SEARCH_TIME_FIELD=vector_search_time

# Название поля с временем лексического поиска (секунды)
LEXICAL_SEARCH_TIME_FIELD=lexical_search_time

# Название поля с временем работы кросс-энкодера (секунды)
CE_SEARCH_TIME_FIELD=cross_encoder_time

# Название поля с полным временем задачи поиска (миллисекунды, будет переведено в секунды)
TOTAL_TASK_SEARCH_TIME_FIELD=full_search_task_time

# Количество документов в итоговой выдаче (top_k) для запроса к API
TOP_K=15

# Лимит числа анализируемых результатов в выдаче (по умолчанию равно TOP_K)
RESULTS_LIMIT=15

# Базовое имя файлов с результатами (JSON/XLSX/JPG), без расширения и даты
OUTPUT_BASENAME=bench_results

# Базовый URL API без завершающего слэша
API_BASE_URL=https://edu.example.com/edu-rest-api/aisearch

# Относительный путь к ручке поиска (POST), объединяется с API_BASE_URL
API_SEARCH_URL=/hybrid-search/search

# Относительный путь к ручке статуса задачи (GET), объединяется с API_BASE_URL
API_INFO_URL=/hybrid-search/info/

# Интервал между запросами статуса задачи (секунды)
API_INFO_INTERVAL=0.2

# Максимальное время ожидания готового результата поиска (секунды)
API_INFO_MAX_TIME=60

# Список значений k, для которых считаются recall/MRR/nDCG (через запятую)
METRICS_KS=1,3,5,10

# Поле со скалярным скором, по которому считается margin@1 (разница score_top1 - score_top2)
MARGIN_SCORE_FIELD=score_final

# Количество top-запросов в диагностических таблицах (самые проблемные/медленные)
DIAG_TOPN=50

# Среднее число отсортированных кандидатов, выводимое в текстовом оверлее
AVG_SORTED_CANDIDATES=20

# Имя поля в метриках, хранящего вес гибридного смешивания для кросс-энкодера
HYBRID_W_CE_FIELD=hybrid_w_ce

# Имя поля в метриках, хранящего вес гибридного смешивания для плотного поиска
HYBRID_W_DENSE=hybrid_w_dense

# Имя поля в метриках, хранящего вес гибридного смешивания для лексического поиска
HYBRID_W_LEX=hybrid_w_lex

# Имя поля в метриках, где указан идентификатор/путь до модели энкодера
ENCODER_MODEL_FIELD=encoder_model

# Имя поля в метриках, где указан идентификатор/путь до модели реранкера
RERANKER_MODEL_FIELD=reranker_model

# Имя поля в метриках с размером пула кандидатов для плотного поиска
HYBRID_DENSE_TOP_K_FIELD=hybrid_dense_top_k

# Имя поля в метриках с размером пула кандидатов для лексического поиска
HYBRID_LEX_TOP_K_FIELD=hybrid_lex_top_k

# Имя поля в метриках с итоговым размером пула кандидатов после объединения
HYBRID_TOP_K_FIELD=hybrid_top_k

# Имя булевого поля, включающего/отключающего реранкер
RERANKER_ENABLE_FLAG=reranker_enabled

# Имя булевого поля, включающего/отключающего BM25
BM25_ENABLE_FLAG=bm_25_enabled

# Имя булевого поля, включающего/отключающего OpenSearch
OPENSEARCH_ENABLE_FLAG=open_search_enabled