# Базовый URL вашего API (без завершающего слэша)
API_BASE_URL=https://edu.example.com/edu-rest-api/aisearch

# Относительный путь к ручке постановки задачи в очередь (POST)
API_SEARCH_PATH=/hybrid-search/search

# Относительный путь к ручке получения статуса задачи (GET), поддерживает {task_id}
API_STATUS_PATH=/hybrid-search/info/{task_id}

# Количество документов в выдаче (top_k), передаётся в API как параметр top_k
API_TOP_K=5

# Читать ли результат из search-cache.
# Для performance-бенчмарка обычно false, иначе измеряется cache-hit, а не реальное выполнение поиска.
API_SEARCH_USE_CACHE=false

# Включить блок info.metrics в ответе поиска.
# Обязательно для metrics-бенчмарка.
API_SEARCH_METRICS_ENABLE=true

# Возвращать ли info.intermediate_results.
# Для metrics-бенчмарка обычно не требуется.
API_SHOW_INTERMEDIATE_RESULTS=false

# Опциональный exact presearch по полю, например ext_id.
# Пустое значение означает, что presearch выключен.
API_PRESEARCH_FIELD=

# Таймаут HTTP-запроса для постановки задачи в очередь (секунды)
API_SEARCH_TIMEOUT=3

# Имя поля в JSON-ответе постановки в очередь, где лежит статус
API_SEARCH_STATUS_FIELD=status

# Значение статуса при успешной постановке в очередь
API_SEARCH_STATUS_OK_VALUE=queued

# Имя поля в JSON-ответе постановки в очередь, где лежит task_id
API_SEARCH_TASK_ID_VALUE=task_id

# Время ожидания перед повтором при коде 423 (переполнение очереди), в секундах
API_SEARCH_OVERFLOW_QUERY_TIMEOUT=3

# Время ожидания перед повтором при коде 429 (лимит запросов), в секундах
API_SEARCH_QUERY_LIMIT_TIMEOUT=3

# Максимальное количество повторных попыток при кодах 423/429 (общий лимит)
API_SEARCH_RETRY_COUNT=5

# Интервал между запросами статуса задачи (миллисекунды)
API_STATUS_REQUEST_INTERVAL=500

# Таймаут HTTP-запроса к ручке статуса (секунды)
API_STATUS_REQUEST_TIMEOUT=60

# Имя поля в JSON-ответе статуса, откуда берётся значение статуса
API_STATUS_STATUS_FIELD=status

# Значение статуса, означающее успешное завершение задачи
API_STATUS_STATUS_OK_VALUE=done

# Статусы, означающие, что задача всё ещё в работе (через запятую)
API_STATUS_INWORK_STATUS_VALUE=queued,running

# Статусы неуспешного завершения задачи (через запятую)
API_STATUS_FAIL_STATUS_VALUE=failed,not_found

# Точечный путь к массиву результатов в JSON-ответе статуса
API_RESULTS_PATH=info.results

# Точечный путь к словарю метрик в JSON-ответе статуса
API_METRICS_PATH=info.metrics

# Название поля с embedding_time (секунды)
API_METRICS_EMBED_TIME_FIELD=embedding_time

# Название поля с временем плотного поиска (vector_search_time, секунды)
API_METRICS_DENSE_TIME_FIELD=vector_search_time

# Название поля с временем лексического поиска (секунды)
API_METRICS_LEX_TIME_FIELD=lexical_search_time

# Название поля с временем работы cross-encoder (секунды)
API_METRICS_CE_TIME_FIELD=cross_encoder_time

# Название поля с общим временем поиска (без постановки в очередь), в секундах
API_METRICS_SEARCH_TIME_FIELD=total_time

# Название поля с полным временем выполнения задачи, в миллисекундах
API_METRICS_TASK_TIME_FIELD=full_search_task_time

# Путь к файлу с запросами (Excel или Parquet). Если пусто — используется TEST_QUERY.
SOURCE_FILE=test_data.xlsx

# Имя колонки в SOURCE_FILE, из которой брать текст запросов
SOURCE_FILE_QUERY_FIELD=

# Тестовый запрос, используемый, если SOURCE_FILE не указан
TEST_QUERY=тестовый запрос

# Сколько раз повторить TEST_QUERY (количество искусственно сгенерированных запросов)
TEST_QUERY_RETRY_COUNT=20

# Top N запросов в выборках по метрикам (для таблиц с самыми медленными/быстрыми)
SORTED_METRICS_TOP_N=5

# Путь к JSON-файлу с агрегированными результатами.
# Если пусто — имя берётся по timestamp в текущей директории.
RESULTS_JSON_PATH=

# Флаг: сохранять ли тела ответов API статуса в отдельный файл (True/False)
SEPARATE_RESULTS_TO_FILE=True

# Путь к файлу, куда сохраняются тела ответов статуса.
# Если пусто и SEPARATE_RESULTS_TO_FILE=True — имя берётся по timestamp.
RESULTS_FILE_PATH=

# Максимальное число статусов, показываемых в колонке "status list" в Top N-таблицах
STATUS_LIST_LIMIT=5
